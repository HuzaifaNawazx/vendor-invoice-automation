      "name": "Invoice Intake",
      "webhookId": "c1a1e001-0000-4000-8000-000000000001"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\nconst errors = [];\nconst ALLOWED_CURRENCIES = ['USD', 'EUR', 'GBP', 'PKR'];\n\nconst api_key = (body.api_key || '').toString().trim();\nconst vendor_id = (body.vendor_id || '').toString().trim();\nconst amountRaw = body.amount;\nconst currency = (body.currency || '').toString().trim().toUpperCase();\n\nif (!api_key) errors.push('api_key is required');\nif (!vendor_id) errors.push('vendor_id is required');\n\nconst amount = Number(amountRaw);\nif (amountRaw === undefined || amountRaw === null || amountRaw === '') {\n  errors.push('amount is required');\n} else if (!Number.isFinite(amount)) {\n  errors.push('amount must be a valid finite number');\n} else if (amount <= 0) {\n  errors.push('amount must be greater than 0');\n} else if (amount > 10000000) {\n  errors.push('amount exceeds the maximum allowed value');\n}\n\nif (!currency) {\n  errors.push('currency is required');\n} else if (!ALLOWED_CURRENCIES.includes(currency)) {\n  errors.push(`currency must be one of: ${ALLOWED_CURRENCIES.join(', ')}`);\n}\n\nreturn [{\n  json: {\n    is_valid: errors.length === 0,\n    validation_errors: errors,\n    api_key,\n    vendor_id,\n    amount,\n    currency\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1200,
        -80
      ],
      "id": "31f84620-f730-4d2e-adaa-a7ea86e6e325",
