# n8n environment variables required by this workflow system.
# Set these on your n8n instance (Docker: pass via -e, or in your docker-compose.yml
# environment: section) — this file is a reference only, n8n does not read it directly.

# Where risk-review and auto-approval notifications are sent.
APPROVER_EMAIL=finance@yourcompany.com

# Public base URL of your n8n instance, used in emailed invoice-submission
# instructions and approve/reject links. Must be reachable by vendors and reviewers.
BASE_URL=https://your-tunnel-or-domain.com
